#: knights_of_the_silver_spire\utils\abilities.cfg:10
msgid "shock"
msgstr ""

#. [attacks]: id=shock
#: knights_of_the_silver_spire\utils\abilities.cfg:11
msgid "When this attack is used on offense, the opponent will retaliate with one less strike than normally, to a minimum of one strike."
msgstr ""

#. [attacks]: id=shock
#: knights_of_the_silver_spire\utils\abilities.cfg:12
msgid "This unit’s melee attack can overwhelm the defenses of enemies, preventing them from retaliating as effectively."
msgstr ""

